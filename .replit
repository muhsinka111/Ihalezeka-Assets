modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 9090
externalPort = 3000

[userenv]

[userenv.shared]
OPERATOR_EMAIL = "info@ihalezeka.com"
STRIPE_PAYMENT_LINK = "https://buy.stripe.com/14AfZh9p219Mddv4aG0Ny0b"
STRIPE_DEFAULT_PRICE_ID = "price_1TjlBRHwO65W7EK00GcgiAuD"
STRIPE_PRO_PRODUCT_ID = "prod_UjDcdkWZMv20x3"

[userenv.development]
ENTITLEMENTS_FORCE_PLAN = "pro"
